      "writtenOn": "2026-07-21T12:40:15Z",
      "side": 1,
      "message": "DSP0266, Section 7.5.3 (https://www.dmtf.org/sites/default/files/standards/documents/DSP0266_1.20.0.pdf)\n\n\"If the resource exists but does not support the requested operation, services shall return the HTTP 405 Method Not Allowed status code.\"",
      "parentUuid": "ec8f311d_62d8ca6c",
      "range": {
        "startLine": 12,
        "startChar": 0,
        "endLine": 17,
        "endChar": 40
      },
