      "writtenOn": "2026-07-17T16:40:45Z",
      "side": 1,
      "message": "Do you know why Redfish Protocol Validator doesn\u0027t flag this?  I thought it was fairly comprehensive for all the protocol level things, and in this case either response was allowed.",
      "range": {
        "startLine": 13,
        "startChar": 0,
        "endLine": 13,
        "endChar": 41
      },
      "revId": "71bedad7c8f1692d7c613474b0dfa8c4cd7c23da",
