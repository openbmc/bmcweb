        "id": 1000153
      },
      "writtenOn": "2026-07-17T16:40:45Z",
      "side": 1,
      "message": "i\u0027m not terribly interested in maintaining this kind of complexity for writing custom 404/405 handlers for every possible URI.  Please make some attempt to show that this isn\u0027t just adding thousands of lines of code if we\u0027re going to do this.",
      "range": {
        "startLine": 19,
        "startChar": 0,
        "endLine": 25,
        "endChar": 27
      },
      "revId": "71bedad7c8f1692d7c613474b0dfa8c4cd7c23da",
