      },
      "writtenOn": "2026-07-24T18:06:48Z",
      "side": 1,
      "message": "\u003e So, returning 405 for a non-existent resource doesn\u0027t break that rule \n\nI think this is key.  What\u0027s there is in compliance.",
      "parentUuid": "23faaebb_cf2590e4",
      "range": {
        "startLine": 13,
        "startChar": 0,
        "endLine": 13,
        "endChar": 41
      },
