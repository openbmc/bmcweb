        "uuid": "fed75ffd_23638065",
        "filename": "redfish-core/lib/fan.hpp",
        "patchSetId": 2
      },
      "lineNbr": 230,
      "author": {
        "id": 1001381
      },
      "writtenOn": "2026-04-23T19:42:08Z",
      "side": 1,
      "message": "Good point. I\u0027ll drop the hardcoded path in the next patchset and use the association walk from the fan\u0027s sensors endpoint instead.",
      "parentUuid": "958fb49f_501f5f86",
      "range": {
        "startLine": 230,
        "startChar": 48,
        "endLine": 230,
        "endChar": 56
      },
      "revId": "e669a12ae1c27719893d3c99f6bfc96e01c85dde",
